{
  "name": "debtctl",
  "version": "0.3.0",
  "description": "Govern npm overrides, pnpm.overrides, and yarn resolutions as documented technical debt. Fails CI when overrides go stale.",
  "bin": {
    "debtctl": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src",
    "prepare": "node -e \"if (process.env.CI) process.exit(0)\" && husky",
    "prepack": "npm run build && npm run lint && npm run typecheck && npm test -- --run"
  },
  "keywords": [
    "npm",
    "pnpm",
    "yarn",
    "overrides",
    "resolutions",
    "dependencies",
    "tech-debt",
    "cli",
    "ci",
    "typescript"
  ],
  "author": "Konstantinos Mavrikas <mavrikas.konstantinos@gmail.com>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KMavr/debtctl.git"
  },
  "bugs": {
    "url": "https://github.com/KMavr/debtctl/issues"
  },
  "homepage": "https://github.com/KMavr/debtctl#readme",
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "semver": "^7.8.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "@types/semver": "^7.7.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
